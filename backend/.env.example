## Backend environment variables (example)
#
# Copy to `.env` for local development.
#
# Server
HOST=0.0.0.0
PORT=8000

## MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=jojo_invoice_tracker

## Auth (JWT)
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

## Bootstrap admin (created on first login if not present)
BOOTSTRAP_ADMIN_EMAIL=appmanager@appjojo.in
BOOTSTRAP_ADMIN_PASSWORD=admin123

## Gmail API (email notifications)
# Path to OAuth client secret JSON (from Google Cloud Console)
GMAIL_CLIENT_SECRET_PATH=client_secret_625886217018-t46dtofa5sifpe5c9566kg93n364e1g9.apps.googleusercontent.com.json
# Path to token file (redirect_uri, access_token, refresh_token, expiry) - run scripts/gmail_oauth_setup.py once to create
GMAIL_TOKEN_PATH=gmail_tokens.json
# Optional: From-address. If empty, the app uses the authenticated Gmail account's email (recommended).
# Gmail only allows sending from the OAuth account; set this only if it matches that account.
GMAIL_SENDER_EMAIL=
# If email stops working after a code update, re-run: python -m scripts.gmail_oauth_setup (to grant new scopes).

## Daily admin report (Mon–Sat 12:00 Asia/Kolkata)
# Single recipient for the daily report email; if empty, all active admin/superadmin users receive it
ADMIN_REPORT_EMAIL=
# System URL shown in the report (e.g. dashboard link)
SYSTEM_URL=

